{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "type": "object",
  "properties": {
    "api": {
      "$ref": "#/$defs/ApiConfig",
      "default": {
        "mock_connection_id_prefix": "debug",
        "mock_target_addr": "mc.hypixel.net:25565",
        "mode": "mock",
        "timeout_ms": 3000,
        "traffic_interval_ms": 5000
      }
    },
    "logging": {
      "$ref": "#/$defs/LoggingConfig",
      "default": {
        "async_enabled": true,
        "format": "pretty",
        "level": "info",
        "stats_log_interval_secs": 10
      }
    },
    "motd": {
      "$ref": "#/$defs/MotdConfig",
      "default": {
        "favicon": {
          "mode": "json"
        },
        "local_json": "{\"version\":{\"name\":\"§bnecron-prism §7status\",\"protocol\":-1},\"players\":{\"max\":100,\"online\":{online_player},\"sample\":[{\"name\":\"§7mode §8> §f{relay_mode}\",\"id\":\"00000000-0000-0000-0000-000000000001\"},{\"name\":\"§7ping §8> §b{ping_mode}\",\"id\":\"00000000-0000-0000-0000-000000000002\"},{\"name\":\"§7target §8> §f{motd_target_addr}\",\"id\":\"00000000-0000-0000-0000-000000000003\"}]},\"description\":{\"text\":\"§bnecron-prism §8» §fclean minecraft relay\\n§7online §f{online_player} §8| §7favicon §f{favicon_mode} §8| §7ping §b{ping_mode}\"}}",
        "mode": "local",
        "ping_mode": "local",
        "protocol": "client",
        "upstream_addr": "mc.hypixel.net:25565",
        "upstream_ping_timeout_ms": 1500
      }
    },
    "network": {
      "$ref": "#/$defs/NetworkConfig",
      "default": {
        "relay": {
          "mode": "async"
        },
        "socket": {
          "first_packet_timeout_ms": 5000,
          "ip_tos": 16,
          "keepalive_secs": 30,
          "listen_addr": "0.0.0.0:25565",
          "listen_backlog": 1024,
          "multipath_tcp": true,
          "reuse_address": true,
          "reuse_port": true,
          "tcp_fastopen": true,
          "tcp_keepalive": true,
          "tcp_nodelay": true,
          "tcp_quickack": true
        }
      }
    }
  },
  "$defs": {
    "ApiConfig": {
      "type": "object",
      "properties": {
        "base_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "bearer_token": {
          "type": [
            "string",
            "null"
          ]
        },
        "mock_connection_id_prefix": {
          "type": "string",
          "default": "debug"
        },
        "mock_kick_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "mock_rewrite_addr": {
          "type": [
            "string",
            "null"
          ]
        },
        "mock_target_addr": {
          "type": "string",
          "default": "mc.hypixel.net:25565",
          "minLength": 1
        },
        "mode": {
          "$ref": "#/$defs/ApiMode",
          "default": "mock"
        },
        "timeout_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 3000,
          "minimum": 0
        },
        "traffic_interval_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 5000,
          "minimum": 0
        }
      }
    },
    "ApiMode": {
      "type": "string",
      "enum": [
        "http",
        "mock"
      ]
    },
    "LogFileConfig": {
      "type": "object",
      "properties": {
        "archive_pattern": {
          "type": "string",
          "default": "{date}-{index}.log.gz"
        },
        "mode": {
          "$ref": "#/$defs/LogRotation",
          "default": "compress"
        },
        "path": {
          "type": "string",
          "default": "data/logs/latest.log"
        }
      }
    },
    "LogFormat": {
      "type": "string",
      "enum": [
        "pretty",
        "compact",
        "json"
      ]
    },
    "LogLevel": {
      "type": "string",
      "enum": [
        "trace",
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "LogRotation": {
      "type": "string",
      "enum": [
        "none",
        "rename",
        "compress"
      ]
    },
    "LoggingConfig": {
      "type": "object",
      "properties": {
        "async_enabled": {
          "type": "boolean",
          "default": true
        },
        "file": {
          "anyOf": [
            {
              "$ref": "#/$defs/LogFileConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "format": {
          "$ref": "#/$defs/LogFormat",
          "default": "pretty"
        },
        "level": {
          "$ref": "#/$defs/LogLevel",
          "default": "info"
        },
        "stats_log_interval_secs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": 10,
          "minimum": 0
        }
      }
    },
    "MotdConfig": {
      "type": "object",
      "properties": {
        "favicon": {
          "$ref": "#/$defs/MotdFaviconConfig",
          "default": {
            "mode": "json"
          }
        },
        "local_json": {
          "type": "string",
          "default": "{\"version\":{\"name\":\"§bnecron-prism §7status\",\"protocol\":-1},\"players\":{\"max\":100,\"online\":{online_player},\"sample\":[{\"name\":\"§7mode §8> §f{relay_mode}\",\"id\":\"00000000-0000-0000-0000-000000000001\"},{\"name\":\"§7ping §8> §b{ping_mode}\",\"id\":\"00000000-0000-0000-0000-000000000002\"},{\"name\":\"§7target §8> §f{motd_target_addr}\",\"id\":\"00000000-0000-0000-0000-000000000003\"}]},\"description\":{\"text\":\"§bnecron-prism §8» §fclean minecraft relay\\n§7online §f{online_player} §8| §7favicon §f{favicon_mode} §8| §7ping §b{ping_mode}\"}}",
          "minLength": 1
        },
        "mode": {
          "$ref": "#/$defs/MotdMode",
          "default": "local"
        },
        "ping_mode": {
          "$ref": "#/$defs/StatusPingMode",
          "default": "local"
        },
        "ping_target_addr": {
          "type": [
            "string",
            "null"
          ]
        },
        "protocol": {
          "$ref": "#/$defs/MotdProtocol",
          "default": "client"
        },
        "upstream_addr": {
          "type": "string",
          "default": "mc.hypixel.net:25565",
          "minLength": 1
        },
        "upstream_ping_timeout_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 1500,
          "minimum": 0
        }
      }
    },
    "MotdFaviconConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/$defs/MotdFaviconMode",
          "default": "json"
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "target_addr": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "MotdFaviconMode": {
      "type": "string",
      "enum": [
        "json",
        "path",
        "passthrough",
        "remove"
      ]
    },
    "MotdMode": {
      "type": "string",
      "enum": [
        "local",
        "upstream"
      ]
    },
    "MotdProtocol": {
      "type": "string",
      "enum": [
        "client",
        "negative_one"
      ]
    },
    "NetworkConfig": {
      "type": "object",
      "properties": {
        "relay": {
          "$ref": "#/$defs/RelayConfig",
          "default": {
            "mode": "async"
          }
        },
        "socket": {
          "$ref": "#/$defs/NetworkSocketConfig",
          "default": {
            "first_packet_timeout_ms": 5000,
            "ip_tos": 16,
            "keepalive_secs": 30,
            "listen_addr": "0.0.0.0:25565",
            "listen_backlog": 1024,
            "multipath_tcp": true,
            "reuse_address": true,
            "reuse_port": true,
            "tcp_fastopen": true,
            "tcp_keepalive": true,
            "tcp_nodelay": true,
            "tcp_quickack": true
          }
        }
      }
    },
    "NetworkSocketConfig": {
      "type": "object",
      "properties": {
        "bind_interface": {
          "type": [
            "string",
            "null"
          ]
        },
        "congestion_control": {
          "type": [
            "string",
            "null"
          ]
        },
        "first_packet_timeout_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 5000,
          "minimum": 0
        },
        "fwmark": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "ip_tos": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "default": 16,
          "maximum": 255,
          "minimum": 0
        },
        "keepalive_secs": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "default": 30,
          "minimum": 0
        },
        "listen_addr": {
          "type": "string",
          "default": "0.0.0.0:25565",
          "minLength": 1
        },
        "listen_backlog": {
          "type": "integer",
          "format": "uint32",
          "default": 1024,
          "minimum": 0
        },
        "multipath_tcp": {
          "type": "boolean",
          "default": true
        },
        "recv_buffer_size": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "reuse_address": {
          "type": "boolean",
          "default": true
        },
        "reuse_port": {
          "type": "boolean",
          "default": true
        },
        "send_buffer_size": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0
        },
        "tcp_fastopen": {
          "type": "boolean",
          "default": true
        },
        "tcp_fastopen_queue": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "tcp_keepalive": {
          "type": "boolean",
          "default": true
        },
        "tcp_nodelay": {
          "type": "boolean",
          "default": true
        },
        "tcp_quickack": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "RelayConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/$defs/RelayMode",
          "default": "async"
        }
      }
    },
    "RelayMode": {
      "type": "string",
      "enum": [
        "async",
        "io_uring",
        "splice"
      ]
    },
    "StatusPingMode": {
      "type": "string",
      "enum": [
        "local",
        "zero_ms",
        "passthrough",
        "disconnect"
      ]
    }
  }
}

  "$defs": {
    "ApiFileConfig": {
      "additionalProperties": false,
      "properties": {
        "base_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "bearer_token": {
          "type": [
            "string",
            "null"
          ]
        },
        "mock": {
          "anyOf": [
            {
              "$ref": "#/$defs/MockApiFileConfig"
            },
            {
              "type": "null"
            }
          ]

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConfigFile",
  "description": "#:schema ./config.schema.json",
  "type": "object",
  "properties": {
    "api": {
      "$ref": "#/$defs/ApiFileConfig",
      "default": {
        "base_url": null,
        "bearer_token": null,
        "mock": {
          "connection_id_prefix": "debug",
          "kick_reason": null,
          "target_addr": "mc.hypixel.net:25565"
        },
        "mode": "mock",
        "timeout_ms": 3000,
        "traffic_interval_ms": 5000
      }
    },
    "inbound": {
      "$ref": "#/$defs/InboundFileConfig",
      "default": {
        "first_packet_timeout_ms": 5000,
        "listen_addr": "0.0.0.0:25565",
        "socket": {
          "keepalive_secs": 30,
          "recv_buffer_size": null,
          "reuse_port": false,
          "send_buffer_size": null,
          "tcp_nodelay": true
        }
      }
    },
    "relay": {
      "$ref": "#/$defs/RelayFileConfig",
      "default": {
        "mode": "standard"
      }
    },
    "runtime": {
      "$ref": "#/$defs/RuntimeFileConfig",
      "default": {
        "stats_log_interval_secs": 10
      }
    },
    "transport": {
      "$ref": "#/$defs/TransportFileConfig",
      "default": {
        "motd": {
          "favicon": {
            "mode": "passthrough",
            "value": null
          },
          "json": "{\"version\":{\"name\":\"Proxy\",\"protocol\":-1},\"players\":{\"max\":100,\"online\":%ONLINE_PLAYER%,\"sample\":[{\"name\":\"Welcome to Proxy\",\"id\":\"00000000-0000-0000-0000-000000000001\"},{\"name\":\"Online: %ONLINE_PLAYER%\",\"id\":\"00000000-0000-0000-0000-000000000002\"}]},\"description\":{\"text\":\"Hello from proxy\"}}",
          "mode": "local",
          "ping_mode": "upstream_tcp",
          "protocol": "client",
          "rewrite": {
            "description_pattern": null,
            "description_replacement": null,
            "favicon_pattern": null,
            "favicon_replacement": null
          },
          "status_cache_ttl_ms": 1000,
          "upstream_addr": "mc.hypixel.net:25565",
          "upstream_ping_timeout_ms": 1500
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ApiFileConfig": {
      "type": "object",
      "properties": {
        "base_url": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "bearer_token": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "mock": {
          "$ref": "#/$defs/MockApiFileConfig",
          "default": {
            "connection_id_prefix": "debug",
            "kick_reason": null,
            "target_addr": "mc.hypixel.net:25565"
          }
        },
        "mode": {
          "$ref": "#/$defs/ApiModeLiteral",
          "default": "mock"
        },
        "timeout_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 3000,
          "minimum": 0
        },
        "traffic_interval_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 5000,
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "ApiModeLiteral": {
      "type": "string",
      "enum": [
        "http",
        "mock"
      ]
    },
    "InboundFileConfig": {
      "type": "object",
      "properties": {
        "first_packet_timeout_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 5000,
          "minimum": 0
        },
        "listen_addr": {
          "type": "string",
          "default": "0.0.0.0:25565"
        },
        "socket": {
          "$ref": "#/$defs/SocketOptionsFileConfig",
          "default": {
            "keepalive_secs": 30,
            "recv_buffer_size": null,
            "reuse_port": false,
            "send_buffer_size": null,
            "tcp_nodelay": true
          }
        }
      },
      "additionalProperties": false
    },
    "MockApiFileConfig": {
      "type": "object",
      "properties": {
        "connection_id_prefix": {
          "type": "string",
          "default": "debug"
        },
        "kick_reason": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "target_addr": {
          "type": "string",
          "default": "mc.hypixel.net:25565"
        }
      },
      "additionalProperties": false
    },
    "MotdFaviconFileConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/$defs/MotdFaviconModeLiteral",
          "default": "passthrough"
        },
        "value": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "MotdFaviconModeLiteral": {
      "type": "string",
      "enum": [
        "passthrough",
        "override",
        "remove"
      ]
    },
    "MotdFileConfig": {
      "type": "object",
      "properties": {
        "favicon": {
          "$ref": "#/$defs/MotdFaviconFileConfig",
          "default": {
            "mode": "passthrough",
            "value": null
          }
        },
        "json": {
          "type": "string",
          "default": "{\"version\":{\"name\":\"Proxy\",\"protocol\":-1},\"players\":{\"max\":100,\"online\":%ONLINE_PLAYER%,\"sample\":[{\"name\":\"Welcome to Proxy\",\"id\":\"00000000-0000-0000-0000-000000000001\"},{\"name\":\"Online: %ONLINE_PLAYER%\",\"id\":\"00000000-0000-0000-0000-000000000002\"}]},\"description\":{\"text\":\"Hello from proxy\"}}"
        },
        "mode": {
          "$ref": "#/$defs/MotdModeLiteral",
          "default": "local"
        },
        "ping_mode": {
          "$ref": "#/$defs/StatusPingModeLiteral",
          "default": "upstream_tcp"
        },
        "protocol": {
          "$ref": "#/$defs/MotdProtocolLiteral",
          "default": "client"
        },
        "rewrite": {
          "$ref": "#/$defs/MotdRewriteFileConfig",
          "default": {
            "description_pattern": null,
            "description_replacement": null,
            "favicon_pattern": null,
            "favicon_replacement": null
          }
        },
        "status_cache_ttl_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 1000,
          "minimum": 0
        },
        "upstream_addr": {
          "type": "string",
          "default": "mc.hypixel.net:25565"
        },
        "upstream_ping_timeout_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 1500,
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "MotdModeLiteral": {
      "type": "string",
      "enum": [
        "local",
        "upstream"
      ]
    },
    "MotdProtocolLiteral": {
      "anyOf": [
        {
          "$ref": "#/$defs/MotdProtocolNamedLiteral"
        },
        {
          "type": "integer",
          "format": "int32"
        }
      ]
    },
    "MotdProtocolNamedLiteral": {
      "type": "string",
      "enum": [
        "client",
        "-1"
      ]
    },
    "MotdRewriteFileConfig": {
      "type": "object",
      "properties": {
        "description_pattern": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "description_replacement": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "favicon_pattern": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "favicon_replacement": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "RelayFileConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/$defs/RelayModeLiteral",
          "default": "standard"
        }
      },
      "additionalProperties": false
    },
    "RelayModeLiteral": {
      "type": "string",
      "enum": [
        "standard",
        "linux_splice"
      ]
    },
    "RuntimeFileConfig": {
      "type": "object",
      "properties": {
        "stats_log_interval_secs": {
          "type": "integer",
          "format": "uint64",
          "default": 10,
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "SocketOptionsFileConfig": {
      "type": "object",
      "properties": {
        "keepalive_secs": {
          "type": "integer",
          "format": "uint64",
          "default": 30,
          "minimum": 0
        },
        "recv_buffer_size": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "default": null,
          "minimum": 0
        },
        "reuse_port": {
          "type": "boolean",
          "default": false
        },
        "send_buffer_size": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "default": null,
          "minimum": 0
        },
        "tcp_nodelay": {
          "type": "boolean",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "StatusPingModeLiteral": {
      "type": "string",
      "enum": [
        "passthrough",
        "0ms",
        "upstream_tcp",
        "disconnect"
      ]
    },
    "TransportFileConfig": {
      "type": "object",
      "properties": {
        "motd": {
          "$ref": "#/$defs/MotdFileConfig",
          "default": {
            "favicon": {
              "mode": "passthrough",
              "value": null
            },
            "json": "{\"version\":{\"name\":\"Proxy\",\"protocol\":-1},\"players\":{\"max\":100,\"online\":%ONLINE_PLAYER%,\"sample\":[{\"name\":\"Welcome to Proxy\",\"id\":\"00000000-0000-0000-0000-000000000001\"},{\"name\":\"Online: %ONLINE_PLAYER%\",\"id\":\"00000000-0000-0000-0000-000000000002\"}]},\"description\":{\"text\":\"Hello from proxy\"}}",
            "mode": "local",
            "ping_mode": "upstream_tcp",
            "protocol": "client",
            "rewrite": {
              "description_pattern": null,
              "description_replacement": null,
              "favicon_pattern": null,
              "favicon_replacement": null
            },
            "status_cache_ttl_ms": 1000,
            "upstream_addr": "mc.hypixel.net:25565",
            "upstream_ping_timeout_ms": 1500
          }
        }
      },
      "additionalProperties": false
    }
  }
}
